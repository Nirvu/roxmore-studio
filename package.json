</div>

<script>
// ── STATE ──
let articles = [];
let qFilter = 'pending';
let selectedIdx = null;
let editIdx = null;
let editDraft = {};

async function loadStorage() {
  try {
    const r = await window.storage.get('roxmore_articles');
    if (r && r.value) articles = JSON.parse(r.value);
  } catch(e) { articles = []; }
  syncStats();
}

function save() {
  try { window.storage.set('roxmore_articles', JSON.stringify(articles)); } catch(e) {}
  syncStats();
}

// ── STATS ──
function syncStats() {
  const tot = articles.length;
  const pend = articles.filter(a=>a.status==='pending').length;
  const live = articles.filter(a=>a.status==='live').length;
  const kw = articles.reduce((s,a)=>s+(a.metaKeywords||[]).length,0);
  document.getElementById('s-total').textContent = tot;
  document.getElementById('s-pend').textContent = pend;
  document.getElementById('s-live').textContent = live;
  document.getElementById('s-seo').textContent = tot ? 'A' : '—';
  document.getElementById('pill-q').textContent = pend;
  document.getElementById('pill-live').textContent = live;
  document.getElementById('m-tot').textContent = tot;
  document.getElementById('m-liv').textContent = live;
  document.getElementById('m-gr').textContent = tot ? 'A' : '—';
  document.getElementById('m-kw').textContent = kw;
  // schema select
  const sel = document.getElementById('schema-sel');
  const prev = sel.value;
  sel.innerHTML = '<option value="">Select an article to preview its schema</option>';
  articles.forEach((a,i)=>{const o=document.createElement('option');o.value=i;o.textContent=a.title;sel.appendChild(o);});
  if(prev) sel.value=prev;
  // refresh board if visible
  const bp = document.getElementById('p-board');
  if(bp && bp.classList.contains('on')) renderBoard();
}

// ── NAV ──
function nav(id, el) {
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.sb-link').forEach(l=>l.classList.remove('on'));
  const p = document.getElementById('p-'+id);
  if(p) p.classList.add('on');
  if(el) el.classList.add('on');
  if(id==='queue') renderQueue();
  if(id==='published') renderPub();
  if(id==='seo') renderSEO();
  if(id==='board') renderBoard();
}

// ── CONTROLS ──
function toggleChk(row){const b=row.querySelector('.chk-box');b.classList.toggle('on')}
function setChip(el,t){document.getElementById('brief').value=t;document.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));el.classList.add('on')}

// ── GENERATE ──
async function generate() {
  const btn = document.getElementById('gen-btn');
  const ps = document.getElementById('prog-section');
  const pf = document.getElementById('prog-fill');
  const pl = document.getElementById('prog-label');
  const log = document.getElementById('gen-log');
  const pulse = document.getElementById('gen-pulse');
  const ptext = document.getElementById('pulse-text');
  const count = parseInt(document.getElementById('cnt').value);
  const brief = document.getElementById('brief').value.trim();

  btn.disabled=true;
  btn.innerHTML='<div class="spinner"></div> Generating...';
  ps.style.display='flex';
  log.style.display='block';
  log.innerHTML='';
  pulse.style.display='flex';

  const msgs = [
    'Researching high-value topics for Roxmore\'s audience...',
    'Analysing search intent and competitor gaps...',
    'Structuring AEO-optimised article briefs...',
    'Writing world-class content...',
    'Applying SEO metadata and schema markup...'
  ];
  let mi=0;
  const msgInterval = setInterval(()=>{if(mi<msgs.length){ptext.textContent=msgs[mi++]}},2200);

  function addLog(msg,type=''){
    const d=document.createElement('div');d.className='log-line '+type;
    d.innerHTML=`<div class="log-dot"></div>${msg}`;
    log.appendChild(d);log.scrollTop=log.scrollHeight;
  }
  function setProg(pct,msg){pf.style.width=pct+'%';pl.textContent=msg}

  setProg(8,'Connecting to AI...');
  await new Promise(r=>setTimeout(r,300));
  addLog('Initialising content engine...');
  setProg(22,'Researching topics...');

  // Sanitise brief to prevent template literal injection
  const safeBrief = brief.replace(/`/g,"'").replace(/\\/g,'');
  const topicLine = brief
    ? 'The user has specified this brief: "' + safeBrief + '". Build ' + count + ' article(s) around this theme, finding ' + count + ' distinct angle(s) if count > 1.'
    : 'Choose ' + count + ' distinct high-value topic(s) from: marketing strategy, demand generation, B2B lead generation, business development, leadership, pricing strategy, performance marketing, content ROI, sales process, growth frameworks. Prioritise topics with strong search intent from UK business owners, MDs, founders.';

  const prompt = `You are a world-class content strategist for Roxmore, a performance marketing and growth consultancy in Surrey, UK, founded by Jem. Roxmore helps business owners, MDs, and founders achieve sustainable strategic growth.

${topicLine}

Write COMPLETE articles of 900-1200 words each, optimised for Google SEO and AEO (cited by ChatGPT, Perplexity, Gemini, Google AI Overviews).

Mandatory AEO structure:
- Open with a "Quick Answer" blockquote (40-60 words) — direct answer to the title question
- Question-based H2 headings throughout
- Factual, authoritative, no-nonsense tone — Roxmore's audience are serious business owners
- End with "Frequently Asked Questions" H2 with 3-4 Q&As

CRITICAL JSON SAFETY — your entire response will be parsed by JSON.parse() so it must be perfectly valid:
- Use straight double quotes only — never curly/smart quotes
- Escape any quote inside a string value with backslash
- No raw newlines inside string values — write HTML on one continuous line or use \\n
- No trailing commas anywhere
- Apostrophes in text (it is, do not, etc) must be escaped as \\u0027 or reworded to avoid them

Return ONLY a valid JSON array of ${count} object(s). No markdown, no preamble, nothing before or after the JSON array. Each object:
- slug, title, category (one of: Growth Strategy/Lead Generation/Marketing/Leadership/Business Development)
- readTime (e.g. "7 min read"), excerpt (2 compelling sentences for blog card)
- metaTitle (55-60 chars), metaDescription (145-155 chars)
- metaKeywords (array of 6 strings)
- faqSchema (array of {question,answer} with 3-4 items)
- body (full HTML: h2 h3 p ul li strong blockquote only, 900+ words)
- publishDate (ISO string, within last 8 weeks of 2025-04-29)
- featured (boolean, true for first only), color, seoScore ("A"), wordCount (integer)`;

  try {
    addLog('Sending to Claude AI...');
    setProg(40,'Writing articles...');
    // Call Netlify function directly using native function URL
    const res = await fetch('/.netlify/functions/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 8000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    setProg(72,'Processing response...');
    clearInterval(msgInterval);
    ptext.textContent='Parsing and validating articles...';
    if(!res.ok){
      let errBody = '';
      try { errBody = await res.text(); } catch(e2) {}
      const errMsg = `API error ${res.status}${errBody ? ': ' + errBody.slice(0,150) : ''}`;
      throw new Error(errMsg);
    }
    const data=await res.json();
    if(!data?.content?.[0]?.text) throw new Error('No content in response');
    let raw=data.content[0].text.trim();
    // Strip markdown fences
    raw=raw.replace(/^```(?:json)?\s*/i,'').replace(/\s*```\s*$/,'').trim();
    // Extract JSON array
    let text=raw;
    if(!text.startsWith('[')){
      const m=text.match(/\[[\s\S]*\]/);
      if(m)text=m[0];
      else{const m2=text.match(/\{[\s\S]*\}/);if(m2)text='['+m2[0]+']';else throw new Error('No JSON array found in response')}
    }
    let parsed;
    try{
      parsed=JSON.parse(text);
    }catch(e){
      // Attempt to fix common JSON issues from AI responses:
      // 1. Replace smart/curly quotes with straight quotes inside string values
      // 2. Fix unescaped newlines inside strings
      addLog('Attempting JSON repair...','');
      try{
        // Remove control characters that break JSON
        let fixed=text
          .replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F]/g,'')  // control chars
          .replace(/\t/g,' ')  // tabs to spaces inside strings
          .replace(/([^\\])\n/g,'$1\\n')  // escape unescaped newlines inside strings
          .replace(/([^\\])\r/g,'$1\\r');  // escape unescaped carriage returns
        parsed=JSON.parse(fixed);
        addLog('JSON repaired successfully','ok');
      }catch(e2){
        // Last resort: use Function constructor as lenient parser
        try{
          parsed=Function('"use strict";return ('+text+')')();
          if(!Array.isArray(parsed))parsed=[parsed];
          addLog('JSON recovered via fallback parser','ok');
        }catch(e3){
          throw new Error('JSON parse failed after repair attempts: '+e.message+' | Raw start: '+text.slice(0,120));
        }
      }
    }
    if(!Array.isArray(parsed))parsed=[parsed];
    if(!parsed.length)throw new Error('Empty result');
    setProg(90,'Finalising...');
    parsed.forEach((a,i)=>{
      a.status='pending';a.id=Date.now()+i;a.generatedAt=new Date().toISOString();
      a.title=a.title||'Untitled';a.slug=a.slug||'article-'+a.id;
      a.metaKeywords=a.metaKeywords||[];a.faqSchema=a.faqSchema||[];a.seoScore=a.seoScore||'A';
      articles.unshift(a);
      addLog(`✓ "${a.title}"`, 'ok');
    });
    save();
    setProg(100,`${parsed.length} article(s) ready for review`);
    addLog(`Done — added to your review queue.`,'ok');
    showToast(`${parsed.length} article(s) generated`, 'ok');
    setTimeout(()=>{
      btn.disabled=false;
      btn.innerHTML='<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 1v12M1 7h12" stroke-linecap="round"/></svg> Generate Articles';
      ps.style.display='none';pf.style.width='0%';pulse.style.display='none';
    },2000);
  } catch(err) {
    clearInterval(msgInterval);
    // Show full error details in the log
    const errDetail = err.message || String(err);
    addLog('✗ Error: ' + errDetail, 'warn');
    console.error('Generation error:', err);
    pulse.style.display='none';
    ps.style.display='none';
    pf.style.width='0%';
    btn.disabled=false;
    btn.innerHTML='<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 1v12M1 7h12" stroke-linecap="round"/></svg> Generate Articles';
    showToast('Generation failed — see log','warn');
  }
}

// ── HELPERS ──
function catEmoji(c){return{'Growth Strategy':'📈','Lead Generation':'🎯','Marketing':'📣','Leadership':'🧭','Business Development':'🤝'}[c]||'📝'}
function fmtDate(d){if(!d)return'';return new Date(d).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}

// ── CARD ──
function buildCard(a,idx,mini=false){
  return `<div class="a-card${selectedIdx===idx?' selected':''}" onclick="selectArticle(${idx})" id="card-${idx}">
    <div class="a-card-top">
      <div class="a-card-icon">${catEmoji(a.category)}</div>
      <div class="a-card-info">
        <div class="a-card-badges">
          <span class="badge b-${a.status}">${a.status}</span>
          <span class="badge b-cat">${a.category}</span>
          ${a.featured?'<span class="badge" style="background:rgba(212,147,90,0.1);color:var(--gold2);border:1px solid var(--gold-border)">Featured</span>':''}
          <span class="badge b-seo">SEO: ${a.seoScore||'A'}</span>
        </div>
        <div class="a-card-title">${a.title}</div>
        ${!mini?`<div class="a-card-excerpt">${a.excerpt||''}</div>`:''}
        <div class="a-card-meta">
          <span class="a-meta-item">${a.readTime||''}</span>
          <span class="a-meta-item">${a.wordCount?a.wordCount+' words':''}</span>
          <span class="a-meta-item">${fmtDate(a.publishDate)}</span>
        </div>
        ${!mini&&a.metaKeywords&&a.metaKeywords.length?`<div class="a-card-keywords">${a.metaKeywords.slice(0,4).map(k=>`<span class="kw">${k}</span>`).join('')}</div>`:''}
        <div class="a-card-actions" onclick="event.stopPropagation()">
          <button class="btn btn-glass btn-sm" onclick="openEditor(${idx})">✏ Edit</button>
          ${a.status==='pending'?`<button class="btn btn-approve btn-sm" onclick="approve(${idx})">✓ Approve</button>`:''}
          ${a.status==='approved'?`<button class="btn btn-publish btn-sm" onclick="publish(${idx})">→ Publish</button>`:''}
          ${a.status==='live'?`<button class="btn btn-ghost btn-sm" onclick="unpublish(${idx})">Unpublish</button>`:''}
          <button class="btn btn-danger btn-sm" onclick="del(${idx})">Delete</button>
        </div>
      </div>
    </div>
  </div>`;
}

function emptyState(t,s){
  return`<div class="empty"><svg class="empty-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M9 12h6M9 16h4M17 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V5a2 2 0 00-2-2z"/></svg><div class="empty-t">${t}</div><div class="empty-s">${s}</div></div>`;
}

// ── SELECT ──
function selectArticle(idx) {
  selectedIdx = idx;
  document.querySelectorAll('.a-card').forEach(c=>c.classList.remove('selected'));
  const card = document.getElementById('card-'+idx);
  if(card) card.classList.add('selected');
  renderPreviewPanel(idx, 'article');
}

function renderPreviewPanel(idx, tab) {
  const a = articles[idx];
  const panel = document.getElementById('q-preview');
  panel.innerHTML = `
    <div class="preview-head">
      <span class="preview-head-label">Preview</span>
      <div style="display:flex;gap:6px">
        ${a.status==='pending'?`<button class="btn btn-approve btn-sm" onclick="approve(${idx});renderQueue()">✓ Approve</button>`:''}
        ${a.status==='approved'?`<button class="btn btn-publish btn-sm" onclick="publish(${idx});renderQueue()">→ Publish</button>`:''}
      </div>
    </div>
    <div class="preview-tabs">
      <div class="p-tab ${tab==='article'?'on':''}" onclick="renderPreviewPanel(${idx},'article')">Article</div>
      <div class="p-tab ${tab==='seo'?'on':''}" onclick="renderPreviewPanel(${idx},'seo')">SEO</div>
      <div class="p-tab ${tab==='schema'?'on':''}" onclick="renderPreviewPanel(${idx},'schema')">Schema</div>
    </div>
    <div class="preview-body">
      ${tab==='article'?`
        <div class="ar-cat">${a.category}</div>
        <div class="ar-title">${a.title}</div>
        <div class="ar-meta"><span>By Jem — Roxmore</span><span>${fmtDate(a.publishDate)}</span><span>${a.readTime||''}</span></div>
        <div class="ar-body">${a.body||'<p>No content.</p>'}</div>
      `:tab==='seo'?`
        <div class="meta-field"><div class="meta-label">Meta Title</div><div class="meta-val">${a.metaTitle||a.title}</div></div>
        <div class="meta-field"><div class="meta-label">Meta Description (${(a.metaDescription||'').length} chars)</div><div class="meta-val">${a.metaDescription||'—'}</div></div>
        <div class="meta-field"><div class="meta-label">URL</div><div class="meta-val" style="font-size:11px">roxmore.co.uk/blog/${a.slug}</div></div>
        <div class="meta-field"><div class="meta-label">Keywords</div><div class="kw-list">${(a.metaKeywords||[]).map(k=>`<span class="kw-tag">${k}</span>`).join('')}</div></div>
      `:`
        <div class="meta-label" style="margin-bottom:8px">JSON-LD Structured Data</div>
        <div class="schema-pre">${buildSchema(a)}</div>
      `}
    </div>`;
}

// ── QUEUE ──
function filterQ(f,el){qFilter=f;document.querySelectorAll('.q-tab').forEach(t=>t.classList.remove('on'));el.classList.add('on');selectedIdx=null;renderQueue()}
function renderQueue(){
  const list=document.getElementById('q-list');
  const filtered=qFilter==='all'?articles.filter(a=>a.status!=='live'):articles.filter(a=>a.status===qFilter);
  if(!filtered.length){list.innerHTML=emptyState('Nothing here','Generate articles to start building your queue.');
    document.getElementById('q-preview').innerHTML='<div class="preview-head"><span class="preview-head-label">Preview</span></div><div class="preview-empty"><svg class="empty-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M9 12h6M9 16h4M17 3H7a2 2 0 00-2 2v14a2 2 0 002 2h10a2 2 0 002-2V5a2 2 0 00-2-2z"/></svg>Select an article to preview</div>';
    return;}
  list.innerHTML=filtered.map(a=>buildCard(a,articles.indexOf(a))).join('');
}
function renderPub(){
  const el=document.getElementById('pub-list');
  const live=articles.filter(a=>a.status==='live');
  el.innerHTML=live.length?live.map(a=>buildCard(a,articles.indexOf(a))).join(''):emptyState('Nothing published yet','Approve and publish articles from the queue.');
}
function renderSEO(){
  const el=document.getElementById('seo-list');
  if(!articles.length){el.innerHTML='<p style="font-size:13px;color:var(--dim)">No articles yet.</p>';return}
  el.innerHTML=articles.map(a=>`<div class="a-card" style="margin-bottom:10px;cursor:default">
    <div class="a-card-badges" style="margin-bottom:8px"><span class="badge b-${a.status}">${a.status}</span><span class="badge b-cat">${a.category}</span><span class="badge b-seo" style="margin-left:auto">SEO: A</span></div>
    <div class="a-card-title" style="margin-bottom:8px">${a.title}</div>
    <div style="font-size:12px;color:var(--dim);line-height:1.6;margin-bottom:5px"><strong style="color:var(--mid)">Meta:</strong> ${a.metaDescription||'—'}</div>
    <div style="font-size:12px;color:var(--dim);margin-bottom:5px"><strong style="color:var(--mid)">Keywords:</strong> ${(a.metaKeywords||[]).join(', ')}</div>
    <div style="font-size:12px;color:var(--dim)"><strong style="color:var(--mid)">Schema:</strong> ${(a.faqSchema||[]).length} FAQ Q&As · Article JSON-LD · AEO Quick Answer ✓</div>
  </div>`).join('');
}

// ── ACTIONS ──
function approve(idx){articles[idx].status='approved';save();renderQueue();if(selectedIdx===idx)renderPreviewPanel(idx,'article');showToast('Approved — ready to publish','ok')}
function publish(idx){articles[idx].status='live';articles[idx].publishedAt=new Date().toISOString();save();renderQueue();showToast('Published! 🚀','ok')}
function unpublish(idx){articles[idx].status='approved';save();renderPub();showToast('Unpublished','warn')}
function del(idx){if(!confirm('Delete this article?'))return;articles.splice(idx,1);selectedIdx=null;save();renderQueue();renderPub();showToast('Deleted','warn')}

// ── EDITOR ──
function openEditor(idx) {
  editIdx = idx;
  editDraft = JSON.parse(JSON.stringify(articles[idx]));
  document.getElementById('ed-title').textContent = 'Edit — ' + editDraft.title.slice(0,40) + (editDraft.title.length>40?'…':'');
  document.querySelectorAll('.e-tab').forEach(t=>t.classList.remove('on'));
  document.querySelector('.e-tab').classList.add('on');
  renderEdTab('content');
  document.getElementById('editor-overlay').classList.add('open');
}
function closeEditor(){document.getElementById('editor-overlay').classList.remove('open')}
function switchEdTab(tab,el){document.querySelectorAll('.e-tab').forEach(t=>t.classList.remove('on'));el.classList.add('on');saveEdFields();renderEdTab(tab)}

function saveEdFields(){
  const ti=document.getElementById('ed-inp-title');if(ti)editDraft.title=ti.value;
  const ex=document.getElementById('ed-inp-excerpt');if(ex)editDraft.excerpt=ex.value;
  // Read from RTE (rich editor) — get innerHTML which is valid HTML
  const rte=document.getElementById('rte-content');
  if(rte) editDraft.body=rte.innerHTML;
  // If source mode is visible, read from textarea instead
  const src=document.getElementById('rte-source');
  if(src && src.style.display!=='none') editDraft.body=src.value;
  const mt=document.getElementById('ed-inp-metatitle');if(mt)editDraft.metaTitle=mt.value;
  const md=document.getElementById('ed-inp-metadesc');if(md)editDraft.metaDescription=md.value;
  const mk=document.getElementById('ed-inp-keywords');if(mk)editDraft.metaKeywords=mk.value.split(',').map(k=>k.trim()).filter(Boolean);
}

function renderEdTab(tab){
  const body=document.getElementById('ed-body');
  const footer=document.getElementById('ed-footer');
  if(tab==='content'){
    body.innerHTML=`
      <div class="ed-field">
        <label class="ed-label">Title</label>
        <input class="ed-input" id="ed-inp-title" value="${esc(editDraft.title||'')}">
      </div>
      <div class="ed-field">
        <label class="ed-label">Excerpt</label>
        <textarea class="ed-input" id="ed-inp-excerpt" style="min-height:60px">${esc(editDraft.excerpt||'')}</textarea>
      </div>
      <div class="ed-field">
        <label class="ed-label" style="margin-bottom:8px">Article Content</label>
        <div class="rte-wrap" id="rte-wrap">
          <!-- Toolbar -->
          <div class="rte-toolbar">
            <select class="rte-select" onchange="rteBlock(this.value);this.value='p'" title="Paragraph style">
              <option value="p">Paragraph</option>
              <option value="h2">Heading 2</option>
              <option value="h3">Heading 3</option>
              <option value="blockquote">Quote</option>
            </select>
            <div class="rte-divider"></div>
            <button class="rte-btn" onclick="rteExec('bold')" title="Bold"><svg viewBox="0 0 14 14" fill="currentColor"><path d="M3 2h4.5a3 3 0 010 6H3V2zM3 8h5a3 3 0 010 6H3V8z"/></svg></button>
            <button class="rte-btn" onclick="rteExec('italic')" title="Italic"><svg viewBox="0 0 14 14" fill="currentColor"><path d="M5 2h6M3 12h6M8 2L6 12"/></svg></button>
            <button class="rte-btn" onclick="rteExec('underline')" title="Underline" style="text-decoration:underline;font-size:11px;font-weight:700">U</button>
            <div class="rte-divider"></div>
            <button class="rte-btn" onclick="rteExec('insertUnorderedList')" title="Bullet list"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 3h8M5 7h8M5 11h8" stroke-linecap="round"/><circle cx="2" cy="3" r="1" fill="currentColor" stroke="none"/><circle cx="2" cy="7" r="1" fill="currentColor" stroke="none"/><circle cx="2" cy="11" r="1" fill="currentColor" stroke="none"/></svg></button>
            <button class="rte-btn" onclick="rteExec('insertOrderedList')" title="Numbered list"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3h7M6 7h7M6 11h7" stroke-linecap="round"/><text x="1" y="4" font-size="4" fill="currentColor" stroke="none">1</text><text x="1" y="8" font-size="4" fill="currentColor" stroke="none">2</text><text x="1" y="12" font-size="4" fill="currentColor" stroke="none">3</text></svg></button>
            <div class="rte-divider"></div>
            <button class="rte-btn" onclick="rteLink()" title="Add link"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5.5 8.5a3 3 0 004.243 0l2-2a3 3 0 00-4.243-4.243l-1 1" stroke-linecap="round"/><path d="M8.5 5.5a3 3 0 00-4.243 0l-2 2a3 3 0 004.243 4.243l1-1" stroke-linecap="round"/></svg></button>
            <button class="rte-btn" onclick="toggleMedia()" title="Insert image or video"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="2" width="12" height="10" rx="1.5"/><path d="M1 9l3-3 3 3 2-2 4 4"/></svg></button>
            <div class="rte-divider"></div>
            <button class="rte-btn" onclick="rteExec('removeFormat')" title="Clear formatting"><svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2h8M6 2v10M9 12H5" stroke-linecap="round"/><path d="M11 9l2 2M13 9l-2 2" stroke-linecap="round"/></svg></button>
          </div>
          <!-- Editable area -->
          <div class="rte-content" id="rte-content" contenteditable="true" data-placeholder="Start writing your article here..."></div>
          <!-- HTML source (hidden by default) -->
          <textarea class="rte-source" id="rte-source" spellcheck="false"></textarea>
          <!-- Media insertion panel -->
          <div class="media-panel" id="media-panel">
            <div class="media-tabs">
              <div class="m-media-tab on" onclick="switchMediaTab('image',this)">🖼 Image</div>
              <div class="m-media-tab" onclick="switchMediaTab('video',this)">▶ Video</div>
              <div class="m-media-tab" onclick="switchMediaTab('unsplash',this)">✦ Unsplash</div>
              <div class="m-media-tab" onclick="switchMediaTab('upload',this)">⬆ Upload</div>
            </div>
            <div class="media-section on" id="ms-image">
              <div class="media-row">
                <span class="media-label">URL</span>
                <input class="media-input" id="img-url" placeholder="https://example.com/image.jpg">
                <button class="btn btn-glass btn-sm" onclick="insertImage()">Insert</button>
              </div>
              <div class="media-row">
                <span class="media-label">Alt text</span>
                <input class="media-input" id="img-alt" placeholder="Describe the image">
              </div>
            </div>
            <div class="media-section" id="ms-video">
              <div class="media-row">
                <span class="media-label">YouTube</span>
                <input class="media-input" id="vid-url" placeholder="https://youtube.com/watch?v=... or youtu.be/...">
                <button class="btn btn-glass btn-sm" onclick="insertVideo()">Embed</button>
              </div>
              <p style="font-size:11px;color:rgba(26,26,26,0.38);margin-top:6px">Paste a YouTube or Vimeo URL — it will embed directly in the article.</p>
            </div>
            <div class="media-section" id="ms-unsplash">
              <div class="media-row">
                <input class="media-input" id="unsplash-q" placeholder="Search Unsplash for free images... (e.g. business, growth, team)">
                <button class="btn btn-glass btn-sm" onclick="searchUnsplash()">Search</button>
              </div>
              <div class="unsplash-grid" id="unsplash-grid"><p style="font-size:12px;color:rgba(26,26,26,0.35);grid-column:span 4;padding:8px 0">Enter a search term above to find free images.</p></div>
            </div>
            <div class="media-section" id="ms-upload">
              <div class="drop-zone" id="upload-drop-zone">
                <input type="file" id="upload-file-input" accept="image/*" onchange="handleFileSelect(event)">
                <div class="drop-zone-icon">🖼</div>
                <div class="drop-zone-label">Drop an image here or click to browse</div>
                <div class="drop-zone-sub">JPG, PNG, WebP, GIF — max 10MB</div>
              </div>
              <div class="upload-preview" id="upload-preview">
                <img id="upload-preview-img" src="" alt="">
                <span class="upload-preview-name" id="upload-preview-name"></span>
                <button class="upload-preview-remove" onclick="clearUpload()">×</button>
              </div>
              <div class="upload-progress" id="upload-progress">
                <div class="upload-progress-fill" id="upload-progress-fill"></div>
              </div>
              <div style="margin-top:10px;display:flex;gap:8px;align-items:center">
                <button class="btn btn-gold btn-sm" onclick="uploadImage()" id="upload-btn" style="display:none">Upload & Insert</button>
                <span id="upload-status" style="font-size:12px;color:var(--dim)"></span>
              </div>
              <p style="font-size:11px;color:rgba(26,26,26,0.35);margin-top:8px">Images are uploaded to Cloudinary (free). Requires Cloudinary credentials in your Netlify environment variables.</p>
            </div>
          </div>
          <!-- Word count footer -->
          <div class="rte-footer">
            <span class="rte-wordcount" id="rte-wc">0 words</span>
            <button class="rte-mode-toggle" id="rte-mode-btn" onclick="toggleRteMode()">View HTML</button>
          </div>
        </div>
      </div>`;
    // Populate RTE with current content
    setTimeout(()=>{
      const rte = document.getElementById('rte-content');
      if(rte){
        rte.innerHTML = editDraft.body || '';
        updateWordCount();
        rte.addEventListener('input', updateWordCount);
        rte.addEventListener('keydown', rteKeyDown);
      }
    },0);
  } else if(tab==='seo'){
    body.innerHTML=`
      <div class="ed-field"><label class="ed-label">Meta Title (55-60 chars)</label><input class="ed-input" id="ed-inp-metatitle" value="${esc(editDraft.metaTitle||'')}"></div>
      <div class="ed-field"><label class="ed-label">Meta Description (145-155 chars)</label><textarea class="ed-input" id="ed-inp-metadesc">${esc(editDraft.metaDescription||'')}</textarea></div>
      <div class="ed-field"><label class="ed-label">Keywords (comma-separated)</label><input class="ed-input" id="ed-inp-keywords" value="${esc((editDraft.metaKeywords||[]).join(', '))}"></div>`;
  } else if(tab==='preview'){
    body.innerHTML=`<div class="ar-cat">${editDraft.category||''}</div><div class="ar-title">${editDraft.title||''}</div><div class="ar-meta"><span>By Jem — Roxmore</span><span>${fmtDate(editDraft.publishDate)}</span><span>${editDraft.readTime||''}</span></div><div class="ar-body">${editDraft.body||'<p>No content.</p>'}</div>`;
  }
  footer.innerHTML=`
    <button class="btn btn-ghost" onclick="closeEditor()">Cancel</button>
    <button class="btn btn-glass" onclick="saveEdit()">Save Changes</button>
    ${editDraft.status==='pending'?`<button class="btn btn-approve" onclick="saveEdit(true)">Save & Approve</button>`:''}`;
}

function saveEdit(andApprove=false){
  saveEdFields();
  articles[editIdx]=Object.assign(articles[editIdx],editDraft);
  if(andApprove)articles[editIdx].status='approved';
  save();renderQueue();
  if(selectedIdx===editIdx)renderPreviewPanel(editIdx,'article');
  closeEditor();
  showToast(andApprove?'Saved & approved':'Changes saved','ok');
}

function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}

// ── SCHEMA ──
function buildSchema(a){
  const art={"@context":"https://schema.org","@type":"Article","headline":a.title,"description":a.metaDescription,"author":{"@type":"Person","name":"Jem","url":"https://roxmore.co.uk"},"publisher":{"@type":"Organization","name":"Roxmore","url":"https://roxmore.co.uk"},"datePublished":a.publishDate,"url":`https://roxmore.co.uk/blog/${a.slug}`,"keywords":(a.metaKeywords||[]).join(', ')};
  let out=JSON.stringify(art,null,2);
  if(a.faqSchema&&a.faqSchema.length){const faq={"@context":"https://schema.org","@type":"FAQPage","mainEntity":a.faqSchema.map(f=>({"@type":"Question","name":f.question,"acceptedAnswer":{"@type":"Answer","text":f.answer}}))};out+='\n\n'+JSON.stringify(faq,null,2)}
  return out.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function renderSchema(){
  const v=document.getElementById('schema-sel').value;
  const el=document.getElementById('schema-out');
  if(!v&&v!==0){el.innerHTML='<div class="schema-pre">Select an article above.</div>';return}
  el.innerHTML=`<div class="schema-pre">${buildSchema(articles[v])}</div>`;
}

// ── EXPORT ──
function exportJSON(){
  const data={meta:{siteName:"Roxmore",siteUrl:"https://roxmore.co.uk",lastUpdated:new Date().toISOString()},posts:articles};
  dl(JSON.stringify(data,null,2),'roxmore-blog.json','application/json');
  showToast('roxmore-blog.json downloaded','ok');
}
function exportPages(){
  const live=articles.filter(a=>a.status==='live');
  if(!live.length){showToast('No published articles to export','warn');return}
  live.forEach(a=>{dl(buildPage(a),a.slug+'.html','text/html')});
  showToast(`${live.length} page(s) exported`,'ok');
}
function dl(content,name,type){
  const b=new Blob([content],{type});const u=URL.createObjectURL(b);
  const a=document.createElement('a');a.href=u;a.download=name;a.click();URL.revokeObjectURL(u);
}

function buildPage(a){
  const art=JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":a.title,"description":a.metaDescription,"author":{"@type":"Person","name":"Jem","url":"https://roxmore.co.uk"},"publisher":{"@type":"Organization","name":"Roxmore","url":"https://roxmore.co.uk"},"datePublished":a.publishDate,"url":`https://roxmore.co.uk/blog/${a.slug}`});
  const faq=a.faqSchema&&a.faqSchema.length?JSON.stringify({"@context":"https://schema.org","@type":"FAQPage","mainEntity":a.faqSchema.map(f=>({"@type":"Question","name":f.question,"acceptedAnswer":{"@type":"Answer","text":f.answer}}))}):'';
  return `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>${a.metaTitle||a.title} | Roxmore</title><meta name="description" content="${a.metaDescription||''}"><meta property="og:title" content="${a.metaTitle||a.title}"><meta property="og:description" content="${a.metaDescription||''}"><meta property="og:url" content="https://roxmore.co.uk/blog/${a.slug}"><meta property="og:type" content="article"><link rel="canonical" href="https://roxmore.co.uk/blog/${a.slug}"><script type="application/ld+json">${art}<\/script>${faq?`<script type="application/ld+json">${faq}<\/script>`:''}<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet"><style>*{box-sizing:border-box;margin:0;padding:0}body{background:#07090F;color:#F0F2F7;font-family:'Cabinet Grotesk',sans-serif;-webkit-font-smoothing:antialiased}nav{position:fixed;top:0;left:0;right:0;height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(20px,6vw,120px);background:rgba(7,9,15,0.9);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.07);z-index:10}.logo{font-size:16px;font-weight:700;letter-spacing:-0.03em}.back{font-size:13px;color:rgba(240,242,247,0.4);transition:color 200ms}.back:hover{color:#F0F2F7}article{max-width:700px;margin:0 auto;padding:90px clamp(20px,6vw,40px) 80px}.cat{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#D4935A;margin-bottom:12px}h1{font-family:'Lora',serif;font-size:clamp(24px,4vw,40px);font-weight:500;letter-spacing:-.01em;line-height:1.15;margin-bottom:16px}.meta{display:flex;gap:18px;font-size:11px;color:rgba(240,242,247,0.3);margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid rgba(255,255,255,0.07);flex-wrap:wrap}h2{font-size:19px;font-weight:600;letter-spacing:-.02em;margin:28px 0 10px}h3{font-size:15px;font-weight:600;margin:20px 0 7px;color:rgba(240,242,247,.85)}p{font-size:16px;font-weight:400;line-height:1.78;color:rgba(240,242,247,.65);margin-bottom:15px}ul{padding-left:20px;margin-bottom:15px}li{font-size:16px;line-height:1.72;color:rgba(240,242,247,.65);margin-bottom:6px}strong{color:#F0F2F7;font-weight:600}blockquote{border-left:2px solid #D4935A;padding:14px 18px;background:rgba(212,147,90,.06);border-radius:0 10px 10px 0;margin:22px 0;font-size:16px;color:rgba(212,147,90,.85);line-height:1.7}footer{text-align:center;padding:40px;border-top:1px solid rgba(255,255,255,.07);font-size:12px;color:rgba(240,242,247,.2)}</style></head><body><nav><a href="/" class="logo">Roxmore</a><a href="/blog" class="back">← Blog</a></nav><article><div class="cat">${a.category}</div><h1>${a.title}</h1><div class="meta"><span>By Jem — Roxmore</span><span>${new Date(a.publishDate).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})}</span><span>${a.readTime||''}</span></div>${a.body||''}</article><footer>© ${new Date().getFullYear()} Roxmore · <a href="https://roxmore.co.uk" style="color:inherit">roxmore.co.uk</a></footer></body></html>`;
}

// ── TOAST ──
function showToast(msg,type=''){
  const t=document.getElementById('toast');
  const p=document.getElementById('toast-pip');
  document.getElementById('toast-txt').textContent=msg;
  p.style.background=type==='ok'?'var(--green)':type==='warn'?'var(--amber)':'var(--gold)';
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);
}

// ── CONTENT BOARD ──
const CAT_GRADIENTS = {
  'Marketing':'grad-marketing',
  'Growth Strategy':'grad-growth',
  'Lead Generation':'grad-lead',
  'Leadership':'grad-leadership',
  'Business Development':'grad-bizdev'
};
const CAT_SHAPES = {
  'Marketing':['#7C3AED','#3B82F6'],
  'Growth Strategy':['#059669','#10B981'],
  'Lead Generation':['#DC2626','#F59E0B'],
  'Leadership':['#1D4ED8','#0EA5E9'],
  'Business Development':['#D97706','#F59E0B']
};
const UNSPLASH = {
  'Marketing':'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=60',
  'Growth Strategy':'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=60',
  'Lead Generation':'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=60',
  'Leadership':'https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=800&q=60',
  'Business Development':'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=60'
};

function renderBoard() {
  const bento = document.getElementById('board-bento');
  const pend = articles.filter(a=>a.status==='pending').length;
  const appr = articles.filter(a=>a.status==='approved').length;
  const live = articles.filter(a=>a.status==='live').length;

  // Update stats
  document.getElementById('bs-total').textContent = articles.length;
  document.getElementById('bs-pend').textContent = pend;
  document.getElementById('bs-appr').textContent = appr;
  document.getElementById('bs-live').textContent = live;
  document.getElementById('pc-pend').textContent = pend;
  document.getElementById('pc-appr').textContent = appr;
  document.getElementById('pc-live').textContent = live;

  if (!articles.length) {
    bento.innerHTML = `<div style="text-align:center;padding:60px 20px;color:var(--dim)">
      <div style="font-size:32px;margin-bottom:12px">✦</div>
      <div style="font-size:16px;font-weight:600;color:var(--mid);margin-bottom:8px">Your board is empty</div>
      <div style="font-size:13px;margin-bottom:20px">Generate your first articles to see them appear here as visual tiles</div>
      <button class="btn btn-gold" onclick="nav('generate',document.querySelector('.sb-link'))">Generate Articles</button>
    </div>`;
    return;
  }

  let html = '';

  // Live articles section
  const liveArticles = articles.filter(a=>a.status==='live');
  if (liveArticles.length) {
    html += `<div class="sh"><div class="sh-title">🟢 Live & Ranking</div></div>`;
    html += `<div class="bento" style="margin-bottom:28px">${buildBentoTiles(liveArticles)}</div>`;
  }

  // Approved section
  const approvedArticles = articles.filter(a=>a.status==='approved');
  if (approvedArticles.length) {
    html += `<div class="sh"><div class="sh-title">✓ Approved — Ready to Publish</div></div>`;
    html += `<div class="bento" style="margin-bottom:28px">${buildBentoTiles(approvedArticles)}</div>`;
  }

  // Pending section
  const pendingArticles = articles.filter(a=>a.status==='pending');
  if (pendingArticles.length) {
    html += `<div class="sh"><div class="sh-title">⏳ Pending Your Review</div></div>`;
    html += `<div class="bento" style="margin-bottom:28px">${buildBentoTiles(pendingArticles)}</div>`;
  }

  // Always show a generate slot
  html += `<div class="sh"><div class="sh-title">Add More Content</div></div>`;
  html += `<div class="bento">
    <div class="bento-tile tile-empty span-4" onclick="nav('generate',document.querySelector('.sb-link'))">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
      <span class="tile-empty-label">Generate New Articles</span>
    </div>
  </div>`;

  bento.innerHTML = html;
}

function buildBentoTiles(list) {
  // Assign spans for visual variety - first card is always large
  const layouts = [
    {col:'span-8',row:'row-2'},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
    {col:'span-6',row:''},
    {col:'span-6',row:''},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
    {col:'span-4',row:''},
  ];

  return list.map((a, i) => {
    const l = layouts[i] || {col:'span-4',row:''};
    const idx = articles.indexOf(a);
    const grad = CAT_GRADIENTS[a.category] || 'grad-default';
    const shapes = CAT_SHAPES[a.category] || ['#374151','#6B7280'];
    const img = UNSPLASH[a.category];
    const isLarge = l.row === 'row-2';
    const isLive = a.status === 'live';
    const isApproved = a.status === 'approved';
    const isPending = a.status === 'pending';

    const statusClass = isPending ? 'ts-pending' : isApproved ? 'ts-approved' : 'ts-live';
    const statusLabel = isPending ? 'Pending' : isApproved ? 'Approved' : 'Live';
    const overlayClass = isPending ? 'tile-overlay-pending' : 'tile-overlay';

    return `<div class="bento-tile ${l.col} ${l.row}" onclick="openEditor(${idx})">
      <!-- background gradient -->
      <div class="tile-bg ${grad}"></div>
      <!-- optional image layer -->
      <div class="tile-bg" style="background-image:url('${img}');opacity:${isPending?'0.25':'0.45'}"></div>
      <!-- decorative shape -->
      <div class="tile-shape" style="width:${isLarge?'280px':'160px'};height:${isLarge?'280px':'160px'};background:${shapes[0]};top:-${isLarge?'80px':'40px'};right:-${isLarge?'60px':'30px'};animation-delay:${i*1.3}s"></div>
      <div class="tile-shape" style="width:${isLarge?'180px':'100px'};height:${isLarge?'180px':'100px'};background:${shapes[1]};bottom:-${isLarge?'40px':'20px'};left:${isLarge?'10%':'5%'};animation-delay:${i*0.7+2}s"></div>
      <!-- overlay -->
      <div class="${overlayClass}"></div>
      <!-- status badge -->
      <div class="tile-status ${statusClass}">${statusLabel}</div>
      <!-- arrow action -->
      <div class="tile-action" onclick="event.stopPropagation();openEditor(${idx})">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 12L12 2M12 2H5M12 2v7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <!-- content -->
      <div class="tile-content">
        <div class="tile-cat">${a.category}</div>
        <div class="tile-title ${isLarge?'lg':''}">${a.title}</div>
        ${isLarge||i===0?`<div class="tile-excerpt">${a.excerpt||''}</div>`:''}
        <div class="tile-meta">
          <span class="tile-meta-item">${a.readTime||''}</span>
          ${a.wordCount?`<div class="tile-dot"></div><span class="tile-meta-item">${a.wordCount} words</span>`:''}
          ${a.publishDate?`<div class="tile-dot"></div><span class="tile-meta-item">${fmtDate(a.publishDate)}</span>`:''}
        </div>
      </div>
      <!-- quick actions - slide up on hover -->
      <div class="tile-quick" onclick="event.stopPropagation()">
        <button class="btn btn-glass btn-sm" style="font-size:11px" onclick="openEditor(${idx})">✏ Edit</button>
        ${isPending?`<button class="btn btn-approve btn-sm" style="font-size:11px" onclick="approve(${idx});renderBoard()">✓ Approve</button>`:''}
        ${isApproved?`<button class="btn btn-publish btn-sm" style="font-size:11px" onclick="publish(${idx});renderBoard()">→ Publish</button>`:''}
        ${isLive?`<button class="btn btn-ghost btn-sm" style="font-size:11px" onclick="unpublish(${idx});renderBoard()">Unpublish</button>`:''}
        <span style="margin-left:auto;font-size:11px;color:var(--dim)">SEO: ${a.seoScore||'A'}</span>
      </div>
    </div>`;
  }).join('');
}


// ── RICH TEXT EDITOR ──
function rteExec(cmd, val=null){
  const rte=document.getElementById('rte-content');
  if(!rte)return;
  rte.focus();
  document.execCommand(cmd,false,val);
  updateWordCount();
}

function rteBlock(tag){
  const rte=document.getElementById('rte-content');
  if(!rte)return;
  rte.focus();
  if(tag==='blockquote'){
    document.execCommand('formatBlock',false,'blockquote');
  } else {
    document.execCommand('formatBlock',false,tag);
  }
}

function rteKeyDown(e){
  // Tab inserts spaces rather than losing focus
  if(e.key==='Tab'){
    e.preventDefault();
    document.execCommand('insertText',false,'    ');
  }
}

function rteLink(){
  const url=prompt('Enter URL:','https://');
  if(url) rteExec('createLink',url);
}

function updateWordCount(){
  const rte=document.getElementById('rte-content');
  const wc=document.getElementById('rte-wc');
  if(!rte||!wc)return;
  const text=rte.innerText||'';
  const words=text.trim().split(/\s+/).filter(w=>w.length>0).length;
  wc.textContent=words+' words';
}

let rteIsSource=false;
function toggleRteMode(){
  const rte=document.getElementById('rte-content');
  const src=document.getElementById('rte-source');
  const btn=document.getElementById('rte-mode-btn');
  if(!rte||!src)return;
  if(!rteIsSource){
    // Switch to HTML source
    src.value=rte.innerHTML;
    rte.style.display='none';
    src.style.display='block';
    btn.textContent='Visual Editor';
    rteIsSource=true;
  } else {
    // Switch back to visual
    rte.innerHTML=src.value;
    src.style.display='none';
    rte.style.display='block';
    btn.textContent='View HTML';
    rteIsSource=false;
    updateWordCount();
  }
}

// ── MEDIA ──
let mediaPanelOpen=false;
function toggleMedia(){
  const panel=document.getElementById('media-panel');
  if(!panel)return;
  mediaPanelOpen=!mediaPanelOpen;
  panel.classList.toggle('open',mediaPanelOpen);
}

function switchMediaTab(tab,el){
  document.querySelectorAll('.m-media-tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.media-section').forEach(s=>s.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('ms-'+tab).classList.add('on');
}

function insertImage(){
  const url=document.getElementById('img-url').value.trim();
  const alt=document.getElementById('img-alt').value.trim()||'Image';
  if(!url){alert('Please enter an image URL');return;}
  const rte=document.getElementById('rte-content');
  if(!rte)return;
  rte.focus();
  document.execCommand('insertHTML',false,`<img src="${url}" alt="${alt}" style="max-width:100%;border-radius:8px;margin:12px 0">`);
  document.getElementById('img-url').value='';
  document.getElementById('img-alt').value='';
  toggleMedia();
  updateWordCount();
}

function insertVideo(){
  const raw=document.getElementById('vid-url').value.trim();
  if(!raw){alert('Please enter a YouTube or Vimeo URL');return;}
  let embedUrl='';
  // YouTube
  const ytMatch=raw.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if(ytMatch)embedUrl=`https://www.youtube.com/embed/${ytMatch[1]}`;
  // Vimeo
  const vimeoMatch=raw.match(/vimeo\.com\/(\d+)/);
  if(vimeoMatch)embedUrl=`https://player.vimeo.com/video/${vimeoMatch[1]}`;
  if(!embedUrl){alert('Could not recognise this URL. Please use a YouTube or Vimeo link.');return;}
  const rte=document.getElementById('rte-content');
  if(!rte)return;
  rte.focus();
  document.execCommand('insertHTML',false,`<div style="position:relative;padding-bottom:56.25%;height:0;margin:16px 0;border-radius:10px;overflow:hidden"><iframe src="${embedUrl}" style="position:absolute;top:0;left:0;width:100%;height:100%;border:none" allowfullscreen></iframe></div>`);
  document.getElementById('vid-url').value='';
  toggleMedia();
}

async function searchUnsplash(){
  const q=document.getElementById('unsplash-q').value.trim();
  if(!q)return;
  const grid=document.getElementById('unsplash-grid');
  grid.innerHTML='<p style="font-size:12px;color:rgba(26,26,26,0.35);grid-column:span 4;padding:8px 0">Searching...</p>';
  // Use Unsplash source API (no key needed for direct image URLs)
  // Generate deterministic image URLs based on the query
  const terms=['business','marketing','growth','team','strategy','leadership','office','meeting'];
  const queries=[q, q+' business', q+' professional', q+' modern'];
  const imgs=queries.map((t,i)=>`https://source.unsplash.com/400x300/?${encodeURIComponent(t)}&sig=${Date.now()+i}`);
  grid.innerHTML=imgs.map((src,i)=>`
    <div class="unsplash-thumb" onclick="insertUnsplashImage('${src}','${q}')">
      <img src="${src}" alt="${q}" loading="lazy" onerror="this.parentElement.style.display='none'">
    </div>`).join('');
}

function insertUnsplashImage(src,alt){
  const rte=document.getElementById('rte-content');
  if(!rte)return;
  rte.focus();
  document.execCommand('insertHTML',false,`<img src="${src}" alt="${alt}" style="max-width:100%;border-radius:8px;margin:12px 0">`);
  const panel=document.getElementById('media-panel');
  if(panel){mediaPanelOpen=false;panel.classList.remove('open');}
  updateWordCount();
}


// ── IMAGE UPLOAD ──
let uploadFile = null;

function handleFileSelect(event) {
  const file = event.target.files[0];
  if (!file) return;
  setUploadFile(file);
}

function setUploadFile(file) {
  if (!file.type.startsWith('image/')) {
    showToast('Please select an image file', 'warn');
    return;
  }
  if (file.size > 10 * 1024 * 1024) {
    showToast('Image must be under 10MB', 'warn');
    return;
  }
  uploadFile = file;
  // Show preview
  const reader = new FileReader();
  reader.onload = (e) => {
    const prev = document.getElementById('upload-preview');
    const img = document.getElementById('upload-preview-img');
    const name = document.getElementById('upload-preview-name');
    const btn = document.getElementById('upload-btn');
    if (prev) { prev.style.display = 'flex'; img.src = e.target.result; name.textContent = file.name; }
    if (btn) btn.style.display = 'inline-flex';
  };
  reader.readAsDataURL(file);
}

function clearUpload() {
  uploadFile = null;
  const prev = document.getElementById('upload-preview');
  const btn = document.getElementById('upload-btn');
  const input = document.getElementById('upload-file-input');
  if (prev) prev.style.display = 'none';
  if (btn) btn.style.display = 'none';
  if (input) input.value = '';
  document.getElementById('upload-status').textContent = '';
}

async function uploadImage() {
  if (!uploadFile) return;
  const btn = document.getElementById('upload-btn');
  const progress = document.getElementById('upload-progress');
  const progressFill = document.getElementById('upload-progress-fill');
  const status = document.getElementById('upload-status');

  btn.disabled = true;
  btn.textContent = 'Uploading...';
  progress.style.display = 'block';
  status.textContent = 'Uploading to Cloudinary...';

  // Animate progress
  let pct = 0;
  const prog = setInterval(() => { pct = Math.min(pct + 8, 85); progressFill.style.width = pct + '%'; }, 200);

  try {
    // Convert to base64
    const base64 = await new Promise((res, rej) => {
      const reader = new FileReader();
      reader.onload = e => res(e.target.result);
      reader.onerror = rej;
      reader.readAsDataURL(uploadFile);
    });

    // Check if we're on Netlify or local
    const isHosted = window.location.hostname !== '' && window.location.protocol === 'https:';
    
    let imageUrl;
    if (isHosted) {
      // Upload via Netlify function
      const res = await fetch('/api/upload', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ file: base64, filename: uploadFile.name }),
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      imageUrl = data.url;
    } else {
      // In Claude artifact / local — use the base64 directly
      imageUrl = base64;
    }

    clearInterval(prog);
    progressFill.style.width = '100%';
    status.textContent = 'Inserted!';

    // Insert into RTE
    const rte = document.getElementById('rte-content');
    if (rte) {
      rte.focus();
      document.execCommand('insertHTML', false, 
        `<img src="${imageUrl}" alt="${uploadFile.name.replace(/\.[^.]+$/, '')}" style="max-width:100%;border-radius:8px;margin:12px 0;display:block">`
      );
    }

    showToast('Image inserted', 'ok');
    setTimeout(() => {
      clearUpload();
      progress.style.display = 'none';
      progressFill.style.width = '0%';
      const panel = document.getElementById('media-panel');
      if (panel) { mediaPanelOpen = false; panel.classList.remove('open'); }
    }, 1000);

  } catch (err) {
    clearInterval(prog);
    progress.style.display = 'none';
    status.textContent = 'Upload failed: ' + err.message;
    btn.disabled = false;
    btn.textContent = 'Upload & Insert';
    showToast('Upload failed: ' + err.message, 'warn');
  }
}

// Drag and drop
document.addEventListener('DOMContentLoaded', () => {
  const dz = document.getElementById('upload-drop-zone');
  if (!dz) return;
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
  dz.addEventListener('drop', e => {
    e.preventDefault();
    dz.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file) setUploadFile(file);
  });
});


// ── INIT ──
loadStorage();
document.getElementById('editor-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('editor-overlay'))closeEditor()});
</script>
